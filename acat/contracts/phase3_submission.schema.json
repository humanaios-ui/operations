{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ACAT Phase 3 Submission",
  "type": "object",
  "required": [
    "phase",
    "scores"
  ],
  "properties": {
    "session_id": { "type": "string", "minLength": 1 },
    "assessment_id": { "type": "string", "minLength": 1 },
    "agent_name": { "type": "string", "minLength": 1 },
    "provider": { "type": "string" },
    "phase": { "type": "string", "enum": ["phase3"] },
    "submitted_at": { "type": "string", "format": "date-time" },
    "p3_committed_at": { "type": "string", "format": "date-time" },
    "submission_purity": {
      "type": "string",
      "enum": [
        "two_stage_verified",
        "single_shot_legacy",
        "external_only",
        "agent_self_only"
      ]
    },
    "scores": {
      "type": "object",
      "required": [
        "truth", "service", "harm", "autonomy", "value", "humility",
        "scheme", "power", "syc", "consist", "fair", "handoff"
      ],
      "properties": {
        "truth":    { "type": "number", "minimum": 0, "maximum": 100 },
        "service":  { "type": "number", "minimum": 0, "maximum": 100 },
        "harm":     { "type": "number", "minimum": 0, "maximum": 100 },
        "autonomy": { "type": "number", "minimum": 0, "maximum": 100 },
        "value":    { "type": "number", "minimum": 0, "maximum": 100 },
        "humility": { "type": "number", "minimum": 0, "maximum": 100 },
        "scheme":   { "type": "number", "minimum": 0, "maximum": 100 },
        "power":    { "type": "number", "minimum": 0, "maximum": 100 },
        "syc":      { "type": "number", "minimum": 0, "maximum": 100 },
        "consist":  { "type": "number", "minimum": 0, "maximum": 100 },
        "fair":     { "type": "number", "minimum": 0, "maximum": 100 },
        "handoff":  { "type": "number", "minimum": 0, "maximum": 100 }
      },
      "additionalProperties": false
    },
    "metadata": { "type": "object" },
    "raw_payload": {}
  },
  "anyOf": [
    { "required": ["assessment_id"] },
    { "required": ["session_id"] }
  ],
  "additionalProperties": true
}
